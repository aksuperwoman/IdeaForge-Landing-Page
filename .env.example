# ── IdeaForge environment ────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.

# NVIDIA NIM API key (get one at https://build.nvidia.com).
# Used server-side ONLY — never sent to the browser.
NVIDIA_API_KEY=nvapi-your-key-here

# NIM model. Default is Nemotron 3 Ultra. test.py used z-ai/glm-5.1;
# both are OpenAI-compatible on the same endpoint.
NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# NIM base URL (OpenAI-compatible).
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Backend port (the FastAPI app that serves the API + frontend).
PORT=8000

# SQLite database file path (created on first run).
DATABASE_URL=sqlite:///./ideaforge.db

# Per-request timeout (seconds) for NIM calls.
NIM_TIMEOUT=180
